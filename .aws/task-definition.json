{
    "family": "ditto-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "runtimePlatform": {
        "cpuArchitecture": "ARM64",
        "operatingSystemFamily": "LINUX"
    },
    "executionRoleArn": "arn:aws:iam::053020126789:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::053020126789:role/ecsTaskRole",
    "containerDefinitions": [
        {
            "name": "ditto-api",
            "image": "public.ecr.aws/u1b1p7p4/ditto-server:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "SPRING_PROFILES_ACTIVE",
                    "value": "prod"
                },
                {
                    "name": "SPRING_DATASOURCE_URL",
                    "value": "jdbc:mysql://localhost:3306/ditto"
                },
                {
                    "name": "SPRING_DATASOURCE_USERNAME",
                    "value": "root"
                }
            ],
            "secrets": [
                {
                    "name": "API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:053020126789:secret:ditto/api-key"
                },
                {
                    "name": "SPRING_DATASOURCE_PASSWORD",
                    "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:053020126789:secret:ditto/db-root-password"
                }
            ],
            "dependsOn": [
                {
                    "containerName": "ditto-db",
                    "condition": "HEALTHY"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ditto-api",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "api"
                }
            }
        },
        {
            "name": "ditto-db",
            "image": "mysql:8.4",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3306,
                    "hostPort": 3306,
                    "protocol": "tcp"
                }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "efs-data",
                    "containerPath": "/var/lib/mysql",
                    "readOnly": false
                }
            ],
            "environment": [
                {
                    "name": "MYSQL_DATABASE",
                    "value": "ditto"
                }
            ],
            "secrets": [
                {
                    "name": "MYSQL_ROOT_PASSWORD",
                    "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:053020126789:secret:ditto/db-root-password"
                }
            ],
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "mysqladmin ping -h localhost -u root --password=$MYSQL_ROOT_PASSWORD || exit 1"
                ],
                "interval": 10,
                "timeout": 5,
                "retries": 5,
                "startPeriod": 30
            },
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ditto-db",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "db"
                }
            }
        },
        {
            "name": "alloy",
            "image": "public.ecr.aws/u1b1p7p4/ditto-alloy:latest",
            "essential": false,
            "command": [
                "run",
                "/etc/alloy/config.alloy",
                "--server.http.listen-addr=0.0.0.0:12345"
            ],
            "secrets": [
                {
                    "name": "GRAFANA_CLOUD_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:053020126789:secret:ditto/grafana-cloud-api-key"
                },
                {
                    "name": "GRAFANA_CLOUD_REMOTE_WRITE_URL",
                    "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:053020126789:secret:ditto/grafana-cloud-remote-write-url"
                },
                {
                    "name": "GRAFANA_CLOUD_USERNAME",
                    "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:053020126789:secret:ditto/grafana-cloud-username"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ditto-alloy",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "alloy"
                }
            }
        }
    ],
    "volumes": [
        {
            "name": "efs-data",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-03a64fd01005335d9",
                "transitEncryption": "ENABLED"
            }
        }
    ]
}
