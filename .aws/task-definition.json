{
  "family": "ditto-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "ditto-api",
      "image": "public.ecr.aws/u1b1p7p4/ditto-server:latest",
      "essential": true,
      "portMappings": [{"containerPort": 8080, "protocol": "tcp"}],
      "environment": [
        {"name": "SPRING_PROFILES_ACTIVE", "value": "prod"},
        {"name": "SPRING_DATASOURCE_URL", "value": "jdbc:mysql://localhost:3306/ditto"},
        {"name": "SPRING_DATASOURCE_USERNAME", "value": "root"}
      ],
      "secrets": [
        {"name": "SPRING_DATASOURCE_PASSWORD", "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:<ACCOUNT_ID>:secret:ditto/db-root-password"},
        {"name": "API_KEY", "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:<ACCOUNT_ID>:secret:ditto/api-key"}
      ],
      "logConfiguration": {"logDriver": "awslogs", "options": {"awslogs-group": "/ecs/ditto-api", "awslogs-region": "ap-northeast-2", "awslogs-stream-prefix": "api"}},
      "dependsOn": [{"containerName": "ditto-db", "condition": "HEALTHY"}]
    },
    {
      "name": "ditto-db",
      "image": "mysql:8.4",
      "essential": true,
      "portMappings": [{"containerPort": 3306, "protocol": "tcp"}],
      "environment": [{"name": "MYSQL_DATABASE", "value": "ditto"}],
      "secrets": [
        {"name": "MYSQL_ROOT_PASSWORD", "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:<ACCOUNT_ID>:secret:ditto/db-root-password"}
      ],
      "healthCheck": {"command": ["CMD-SHELL", "mysqladmin ping -h localhost -u root --password=$MYSQL_ROOT_PASSWORD || exit 1"], "interval": 10, "timeout": 5, "retries": 5, "startPeriod": 30},
      "logConfiguration": {"logDriver": "awslogs", "options": {"awslogs-group": "/ecs/ditto-db", "awslogs-region": "ap-northeast-2", "awslogs-stream-prefix": "db"}}
    },
    {
      "name": "alloy",
      "image": "public.ecr.aws/u1b1p7p4/ditto-alloy:latest",
      "essential": false,
      "command": ["run", "/etc/alloy/config.alloy", "--server.http.listen-addr=0.0.0.0:12345"],
      "secrets": [
        {"name": "GRAFANA_CLOUD_REMOTE_WRITE_URL", "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:<ACCOUNT_ID>:secret:ditto/grafana-cloud-remote-write-url"},
        {"name": "GRAFANA_CLOUD_USERNAME", "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:<ACCOUNT_ID>:secret:ditto/grafana-cloud-username"},
        {"name": "GRAFANA_CLOUD_API_KEY", "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:<ACCOUNT_ID>:secret:ditto/grafana-cloud-api-key"}
      ],
      "logConfiguration": {"logDriver": "awslogs", "options": {"awslogs-group": "/ecs/ditto-alloy", "awslogs-region": "ap-northeast-2", "awslogs-stream-prefix": "alloy"}}
    }
  ]
}
